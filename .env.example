# ============================================================
#  Si Bakat Hebat — contoh environment
#  LOKAL: pakai MySQL/SQLite seperti di bawah.
#  PRODUKSI (Render, gratis): APP_ENV=production, APP_DEBUG=false,
#  DB_CONNECTION=pgsql, dan DB_* diisi otomatis dari database Render.
#  Lihat DEPLOY-RENDER.md untuk langkah lengkap.
# ============================================================
APP_NAME="Si Bakat Hebat"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Password akun staf yang dibuat seeder SAAT PERTAMA KALI saja.
# Akun yang sudah ada tidak pernah ditimpa. Wajib diisi di produksi —
# kalau kosong, seeder membuat password acak & menampilkannya sekali di log.
ADMIN_PASSWORD=
GURU_PASSWORD=

# Setup DB lewat browser (hosting tanpa CLI). Minimal 32 karakter acak,
# kalau lebih pendek route-nya mati. Hapus lagi setelah setup selesai.
APP_SETUP_TOKEN=

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=minatbakattest
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sefinalika@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=sefinalika@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Kontak WhatsApp (footer). Boleh format 08xx (otomatis diubah ke 62xx untuk wa.me)
WHATSAPP_NUMBER=082122945262

# Token setup DB via browser (hosting tanpa command line). Isi acak, kunjungi
# /deploy/setup/TOKEN sekali untuk migrasi+seed, lalu KOSONGKAN lagi.
APP_SETUP_TOKEN=
